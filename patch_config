#!/usr/bin/env python3
import json
from pathlib import Path

def patch_installed_plugin_config():
    # 1. Locate the canonical installation directory
    installed_dir = Path("~/.gemini/config/plugins/architecture-registry").expanduser().resolve()
    config_path = installed_dir / "mcp_config.json"
    
    if not config_path.exists():
        print(f"Error: Installed config not found at {config_path}")
        return

    # 2. Read the installed configuration file
    with open(config_path, "r") as f:
        config_text = f.read()

    # 3. Replace the template placeholder with the actual installed absolute path
    updated_text = config_text.replace("${pluginPath}", str(installed_dir))

    # 4. Save the patched configuration back to the installed directory
    with open(config_path, "w") as f:
        f.write(updated_text)

    print(f"Successfully patched {config_path} to use absolute path: {installed_dir}")

if __name__ == "__main__":
    patch_installed_plugin_config()
